---
interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  sizes?: string;
  fallbackLabel?: string;
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  fetchpriority = 'auto',
  sizes,
  fallbackLabel = 'Image unavailable',
  class: className,
} = Astro.props as Props;

const inferredSizes = sizes ?? (className?.includes('card__media--hero')
  ? '(max-width: 720px) calc(100vw - 2rem), (max-width: 1100px) 44vw, 540px'
  : className?.includes('card__media--portrait')
    ? '(max-width: 720px) calc(100vw - 2rem), (max-width: 960px) 44vw, 360px'
    : className?.includes('card__media--cta')
      ? '(max-width: 720px) calc(100vw - 2rem), (max-width: 1100px) 42vw, 520px'
      : className?.includes('card__media--landscape')
        ? '(max-width: 720px) calc(100vw - 2rem), (max-width: 960px) 48vw, 420px'
        : '100vw');

const hasJpgSource = /\.jpe?g$/i.test(src);
const webpBase = hasJpgSource ? src.replace(/\.jpe?g$/i, '') : '';
const webp720 = hasJpgSource ? `${webpBase}-720.webp` : '';
const webp1080 = hasJpgSource ? `${webpBase}-1080.webp` : '';
---

<div class:list={['card__media', 'media-frame', className]} data-image-frame>
  {hasJpgSource ? (
    <picture>
      <source type="image/webp" srcset={`${webp720} 720w, ${webp1080} 1080w`} sizes={inferredSizes} />
      <img
        src={src}
        alt={alt}
        width={width}
        height={height}
        loading={loading}
        decoding="async"
        fetchpriority={fetchpriority}
        sizes={inferredSizes}
        onerror="const imageFrameA = this.closest('[data-image-frame]'); if (imageFrameA) imageFrameA.dataset.imageMissing = 'true'; this.style.display = 'none';"
      />
    </picture>
  ) : (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
      sizes={inferredSizes}
      onerror="const imageFrameB = this.closest('[data-image-frame]'); if (imageFrameB) imageFrameB.dataset.imageMissing = 'true'; this.style.display = 'none';"
    />
  )}
  <span class="media-frame__fallback" aria-hidden="true">{fallbackLabel}</span>
</div>
