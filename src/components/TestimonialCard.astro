---
interface Props {
  label: string;
  quote: string;
  name: string;
  role: string;
}

const { label, quote, name, role } = Astro.props as Props;
---

<figure class="card testimonial-card">
  <div class="testimonial-card__body">
    <p class="testimonial-card__label">{label}</p>
    <blockquote>{quote}</blockquote>
  </div>
  <figcaption>
    <strong>{name}</strong>
    <span>{role}</span>
  </figcaption>
</figure>

<style>
  .testimonial-card {
    display: grid;
    gap: 1.15rem;
    min-height: 100%;
  }

  .testimonial-card__body {
    display: grid;
    gap: 0.75rem;
  }

  .testimonial-card__label {
    margin: 0;
    color: var(--accent-strong);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    font-weight: 700;
  }

  blockquote {
    margin: 0;
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  figcaption {
    display: grid;
    gap: 0.1rem;
    color: var(--muted);
  }

  figcaption strong {
    color: var(--text);
  }

  .testimonial-card__body,
  figcaption {
    padding-inline: 1.4rem;
  }

  .testimonial-card__body {
    padding-top: 1.4rem;
  }

  figcaption {
    padding-bottom: 1.4rem;
  }
</style>
