---
interface Props {
  label: string;
  quote: string;
  name: string;
  role: string;
}

const { label, quote, name, role } = Astro.props as Props;
---

<figure class="card testimonial-card">
  <div class="testimonial-card__body">
    <p class="testimonial-card__label">{label}</p>
    <blockquote>{quote}</blockquote>
  </div>
  <figcaption>
    <strong>{name}</strong>
    <span>{role}</span>
  </figcaption>
</figure>
