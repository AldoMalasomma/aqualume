---
import ImageFrame from './ImageFrame.astro';

const { name, title, focus, image, alt, width, height } = Astro.props;
---

<article class="card team-card">
  <ImageFrame
    src={image}
    alt={alt}
    width={width}
    height={height}
    loading="lazy"
    fallbackLabel={name}
    class="card__media--portrait team-card__media"
  />
  <div class="card__body team-card__body">
    <h3>{name}</h3>
    <p class="team-card__title">{title}</p>
    <p>{focus}</p>
  </div>
</article>
