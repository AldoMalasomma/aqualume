---
import ImageFrame from './ImageFrame.astro';

type HeroStat = {
  value: string;
  label: string;
};

type HeroAction = {
  href: string;
  label: string;
};

type HeroImage = {
  src: string;
  alt: string;
  width: number;
  height: number;
};

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryAction?: HeroAction;
  secondaryAction?: HeroAction;
  image?: HeroImage;
  mediaCaption?: string;
  trustItems?: string[];
  stats?: HeroStat[];
  compact?: boolean;
}

const {
  eyebrow,
  title,
  description,
  primaryAction,
  secondaryAction,
  image,
  mediaCaption,
  trustItems = [],
  stats = [],
  compact = false,
} = Astro.props as Props;
---

<section class:list={['hero', compact && 'hero--compact']}>
  <div class="hero__frame">
    <div class="site-shell">
      <div class="surface hero__inner">
        <div class="hero__content">
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          <h1>{title}</h1>
          <p class="hero__description">{description}</p>

          <div class="hero__actions">
            {primaryAction && (
              <a class="button button--primary" href={primaryAction.href}>
                {primaryAction.label}
              </a>
            )}
            {secondaryAction && (
              <a class="button button--secondary" href={secondaryAction.href}>
                {secondaryAction.label}
              </a>
            )}
          </div>

          {trustItems.length > 0 && (
            <ul class="hero__trust" aria-label="Trust markers">
              {trustItems.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}

          {stats.length > 0 && (
            <dl class="hero__stats">
              {stats.map((stat) => (
                <div class="hero__stat">
                  <dt>{stat.value}</dt>
                  <dd>{stat.label}</dd>
                </div>
              ))}
            </dl>
          )}
        </div>

        {image && (
          <figure class="hero__media">
            <ImageFrame
              src={image.src}
              alt={image.alt}
              width={image.width}
              height={image.height}
              loading="eager"
              fetchpriority="high"
              fallbackLabel="Clinic interior"
              class="card__media--hero hero__media-frame"
            />
            {mediaCaption && <figcaption>{mediaCaption}</figcaption>}
          </figure>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: clamp(1rem, 2.5vw, 1.75rem) 0 clamp(1.25rem, 4vw, 2.5rem);
    overflow: clip;
  }

  .hero__frame {
    position: relative;
  }

  .hero__frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 10%, rgba(105, 207, 200, 0.18), transparent 28%),
      radial-gradient(circle at 80% 15%, rgba(201, 240, 233, 0.5), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(238, 248, 246, 0.16));
    border-block: 1px solid rgba(20, 110, 110, 0.08);
    pointer-events: none;
    z-index: -1;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(280px, 0.92fr);
    align-items: stretch;
    gap: clamp(1rem, 3vw, 2.25rem);
    padding: clamp(1rem, 3vw, 1.4rem);
    border-radius: calc(var(--radius-xl) + 8px);
    overflow: hidden;
    position: relative;
  }

  .hero__content {
    display: grid;
    align-content: center;
    gap: 1rem;
    padding: clamp(1.4rem, 4vw, 3.2rem) clamp(0.25rem, 2vw, 1rem) clamp(1.25rem, 4vw, 3rem) 0;
  }

  .hero h1 {
    margin: 0;
    max-width: 10ch;
    font-size: clamp(3rem, 7vw, 6.1rem);
    line-height: 0.95;
    letter-spacing: -0.07em;
  }

  .hero__description {
    max-width: 40rem;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.02rem, 1.8vw, 1.14rem);
    line-height: 1.72;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.1rem;
  }

  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0.4rem 0 0;
    padding: 0;
    list-style: none;
  }

  .hero__trust li {
    display: inline-flex;
    align-items: center;
    min-height: 2.2rem;
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    background: rgba(223, 247, 242, 0.82);
    color: var(--accent-strong);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    margin: 0.75rem 0 0;
  }

  .hero__stat {
    padding: 1rem 1rem 0.95rem;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(20, 110, 110, 0.08);
  }

  .hero__stat dt {
    font-size: 1.55rem;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .hero__stat dd {
    margin: 0.35rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .hero__media {
    margin: 0;
    border-radius: calc(var(--radius-xl) - 4px);
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(105, 207, 200, 0.16), transparent 32%),
      linear-gradient(180deg, #d8f3ef, #eefaf8);
    position: relative;
    align-self: stretch;
  }

  .hero__media-frame {
    --media-position: center 18%;
  }

  .hero__media figcaption {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    padding: 0.8rem 0.95rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(20, 110, 110, 0.1);
    box-shadow: var(--shadow-sm);
    color: var(--text);
    font-size: 0.88rem;
    line-height: 1.5;
    backdrop-filter: blur(10px);
  }

  .hero--compact .hero__inner {
    grid-template-columns: minmax(0, 1fr) minmax(240px, 0.75fr);
  }

  .hero--compact .hero h1 {
    max-width: 13ch;
    font-size: clamp(2.3rem, 5vw, 4.4rem);
  }

  @media (max-width: 860px) {
    .hero__inner,
    .hero--compact .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__content {
      padding: 0.25rem 0.1rem 0.75rem;
    }

    .hero__stats {
      grid-template-columns: 1fr;
    }

    .hero__media,
    .hero--compact .hero__media {
      aspect-ratio: 16 / 11;
    }

    .hero__media-frame {
      --media-ratio: 16 / 11;
    }

    .hero__media figcaption {
      left: 0.85rem;
      right: 0.85rem;
      bottom: 0.85rem;
      padding: 0.75rem 0.85rem;
    }
  }
</style>
