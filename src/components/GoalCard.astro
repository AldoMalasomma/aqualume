---
interface Props {
  label: string;
  description: string;
  href: string;
}

const { label, description, href } = Astro.props as Props;
---

<a class="card goal-card" href={href}>
  <div class="goal-card__body">
    <p class="goal-card__label">{label}</p>
    <p class="goal-card__description">{description}</p>
  </div>
  <span class="goal-card__arrow" aria-hidden="true">→</span>
</a>

<style>
  .goal-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: 1.15rem 1.15rem 1.1rem;
    min-height: 100%;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .goal-card:hover {
    transform: translateY(-2px);
    border-color: rgba(20, 110, 110, 0.2);
    box-shadow: var(--shadow-lg);
  }

  .goal-card__body {
    display: grid;
    gap: 0.4rem;
  }

  .goal-card__label {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 650;
    color: var(--text);
  }

  .goal-card__description {
    margin: 0;
    color: var(--muted);
    font-size: 0.93rem;
    line-height: 1.55;
  }

  .goal-card__arrow {
    color: var(--accent-strong);
    font-size: 1.1rem;
  }
</style>
