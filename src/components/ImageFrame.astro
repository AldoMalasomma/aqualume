---
interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  fallbackLabel?: string;
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  fetchpriority = 'auto',
  fallbackLabel = 'Image unavailable',
  class: className,
} = Astro.props as Props;
---

<div class:list={['card__media', 'media-frame', className]} data-image-frame>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
    onerror="const frame = this.closest('[data-image-frame]'); if (frame) frame.dataset.imageMissing = 'true'; this.style.display = 'none';"
  />
  <span class="media-frame__fallback" aria-hidden="true">{fallbackLabel}</span>
</div>

<style>
  .media-frame {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .media-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--media-position, center center);
  }

  .media-frame__fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 1rem;
    text-align: center;
    background:
      radial-gradient(circle at top left, rgba(201, 240, 233, 0.4), transparent 38%),
      linear-gradient(180deg, #edf9f8, #d8f3ef);
    color: var(--accent-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .media-frame[data-image-missing='true'] .media-frame__fallback {
    opacity: 1;
  }

  .media-frame[data-image-missing='true'] img {
    display: none;
  }
</style>
