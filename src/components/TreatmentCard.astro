---
import ImageFrame from './ImageFrame.astro';

interface Props {
  name: string;
  category: string;
  description: string;
  details: string[];
  image: string;
  alt: string;
  width: number;
  height: number;
}

const { name, category, description, details, image, alt, width, height } = Astro.props as Props;
---

<article class="card treatment-card">
  <ImageFrame
    src={image}
    alt={alt}
    width={width}
    height={height}
    loading="lazy"
    fallbackLabel={name}
    class="card__media--treatment"
  />
  <div class="card__body treatment-card__body">
    <p class="treatment-card__category">{category}</p>
    <h3>{name}</h3>
    <p>{description}</p>
    <ul class="treatment-card__meta">
      {details.map((detail) => (
        <li>{detail}</li>
      ))}
    </ul>
  </div>
</article>
