---
import ImageFrame from './ImageFrame.astro';

type HeroStat = {
  value: string;
  label: string;
};

type HeroAction = {
  href: string;
  label: string;
};

type HeroImage = {
  src: string;
  alt: string;
  width: number;
  height: number;
};

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryAction?: HeroAction;
  secondaryAction?: HeroAction;
  image?: HeroImage;
  mediaCaption?: string;
  trustItems?: string[];
  stats?: HeroStat[];
  compact?: boolean;
}

const {
  eyebrow,
  title,
  description,
  primaryAction,
  secondaryAction,
  image,
  mediaCaption,
  trustItems = [],
  stats = [],
  compact = false,
} = Astro.props as Props;
---

<section class:list={['hero', compact && 'hero--compact']}>
  <div class="hero__frame">
    <div class="site-shell">
      <div class="surface hero__inner">
        <div class="hero__content">
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          <h1>{title}</h1>
          <p class="hero__description">{description}</p>

          <div class="hero__actions">
            {primaryAction && (
              <a class="button button--primary" href={primaryAction.href}>
                {primaryAction.label}
              </a>
            )}
            {secondaryAction && (
              <a class="button button--secondary" href={secondaryAction.href}>
                {secondaryAction.label}
              </a>
            )}
          </div>

          {trustItems.length > 0 && (
            <ul class="hero__trust" aria-label="Trust markers">
              {trustItems.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}

          {stats.length > 0 && (
            <dl class="hero__stats">
              {stats.map((stat) => (
                <div class="hero__stat">
                  <dt>{stat.value}</dt>
                  <dd>{stat.label}</dd>
                </div>
              ))}
            </dl>
          )}
        </div>

        {image && (
          <figure class="hero__media">
            <ImageFrame
              src={image.src}
              alt={image.alt}
              width={image.width}
              height={image.height}
              loading="eager"
              fetchpriority="high"
              fallbackLabel="Clinic interior"
              class="card__media--hero hero__media-frame"
            />
            {mediaCaption && <figcaption>{mediaCaption}</figcaption>}
          </figure>
        )}
      </div>
    </div>
  </div>
</section>
